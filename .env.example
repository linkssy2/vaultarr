# Vaultarr environment example
# Copy to .env only for local development. Do not commit real secrets.

TZ=America/Los_Angeles
VAULTARR_PORT=5058
VAULTARR_CONFIG=/config
VAULTARR_GAMES=/games
VAULTARR_BACKUPS=/backups

# Optional provider credentials. Leave blank unless configured by the user.
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
RAWG_API_KEY=
STEAMGRIDDB_API_KEY=
YOUTUBE_API_KEY=
